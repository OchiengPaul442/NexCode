{
  "name": "nexcode-kiboko",
  "displayName": "Kiboko for VS Code",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://example.com/your/repo.git"
  },
  "publisher": "your-name",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:kiboko.helloWorld",
    "onCommand:kiboko.openChat",
    "onCommand:kiboko.openDiffReview",
    "onCommand:kiboko.openAuditLog",
    "onCommand:kiboko.manageDenylist"
  ],
  "scripts": {
    "vscode:prepublish": "npm run build:webview && npm run compile",
    "build:webview": "esbuild src/webview-src/index.tsx --bundle --minify --sourcemap --outfile=media/webview.js --loader:.svg=dataurl --target=es2020",
    "watch:webview": "esbuild src/webview-src/index.tsx --bundle --sourcemap --outfile=media/webview.js --loader:.svg=dataurl --target=es2020 --watch",
    "compile": "npm run build:webview && tsc -p .",
    "watch": "tsc -w -p .",
    "package": "vsce package",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "esbuild": "^0.19.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/test-electron": "^2.5.2",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.1.6",
    "vsce": "^2.5.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "kiboko.helloWorld",
        "title": "Kiboko: Hello World"
      },
      {
        "command": "kiboko.openChat",
        "title": "Kiboko: Open Chat"
      },
      {
        "command": "kiboko.openDiffReview",
        "title": "Kiboko: Open Diff Review"
      },
      {
        "command": "kiboko.openAuditLog",
        "title": "Kiboko: Open Audit Log"
      },
      {
        "command": "kiboko.manageDenylist",
        "title": "Kiboko: Manage Denylist"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Pulse",
      "properties": {
        "pulse.provider": {
          "type": "string",
          "default": "ollama",
          "description": "Provider to use for completions (ollama, openai)."
        },
        "pulse.ollamaBaseUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL for the local Ollama server."
        },
        "pulse.ollamaModel": {
          "type": "string",
          "default": "llama2",
          "description": "Default Ollama model to use."
        },
        "pulse.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for OpenAI (if using OpenAI provider)."
        },
        "pulse.openaiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com",
          "description": "Base URL for OpenAI API (use for local mocks/tests)."
        },
        "pulse.openaiModel": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Default OpenAI model to use."
        },
        "pulse.streamChunkDelay": {
          "type": "number",
          "default": 120,
          "description": "Synthetic delay for mock streams (ms)."
        },
        "pulse.inlineDebounceMs": {
          "type": "number",
          "default": 200,
          "description": "Debounce window for inline completions (ms)."
        },
        "pulse.inlineMaxCompletionChars": {
          "type": "number",
          "default": 2000,
          "description": "Maximum number of characters returned by inline completion (truncation)."
        },
        "pulse.inlinePrefixChars": {
          "type": "number",
          "default": 800,
          "description": "Number of characters before the cursor sent as prefix for inline completion."
        },
        "pulse.inlineSuffixChars": {
          "type": "number",
          "default": 400,
          "description": "Number of characters after the cursor sent as suffix for inline completion."
        },
        "pulse.denylist": {
          "type": "array",
          "description": "Denylist rules for commands and file paths. Each rule can be toggled and assigned a risk level.",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Optional rule id"
              },
              "pattern": {
                "type": "string",
                "description": "Command or file path pattern (glob or substring). Prefix with `re:` to use a JS RegExp."
              },
              "type": {
                "type": "string",
                "enum": [
                  "command",
                  "file"
                ],
                "default": "command",
                "description": "Whether the pattern targets commands or file paths"
              },
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "risk": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ],
                "default": "high",
                "description": "Risk level: high=deny, medium=ask, low=allow"
              },
              "description": {
                "type": "string",
                "description": "Human-readable explanation for the rule"
              }
            },
            "additionalProperties": false
          }
        },
        "pulse.policy": {
          "type": "object",
          "description": "Policy settings for safety and denylist behavior.",
          "properties": {
            "askRiskThreshold": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ],
              "default": "medium",
              "description": "Risk level at or above which the system will ask the user before executing."
            }
          }
        }
      }
    },
    "chatParticipants": [
      {
        "id": "pulse.pulseforge",
        "name": "pulseforge",
        "fullName": "Pulse Forge",
        "description": "Route chat requests through Pulse providers",
        "isSticky": false,
        "commands": [
          {
            "name": "explain",
            "description": "Explain code or selection"
          },
          {
            "name": "fix",
            "description": "Propose fixes for code"
          },
          {
            "name": "generate",
            "description": "Generate code or content"
          }
        ]
      }
    ]
  }
}
