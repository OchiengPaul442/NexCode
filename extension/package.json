{
  "name": "nexcode-kiboko-extension",
  "displayName": "Nexcode Kiboko",
  "description": "Local-first, multi-agent AI coding assistant for VS Code.",
  "publisher": "nexcode",
  "version": "0.1.41",
  "private": true,
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "keywords": [
    "ai",
    "chat",
    "agent",
    "ollama",
    "code-review",
    "developer-tools"
  ],
  "license": "MIT",
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nexcodeKiboko",
          "title": "NexCode",
          "icon": "media/activitybar-icon.svg"
        }
      ]
    },
    "views": {
      "nexcodeKiboko": [
        {
          "id": "nexcodeKiboko.sidebarView",
          "name": "Nexcode Kiboko",
          "icon": "media/kiboko.svg",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "nexcodeKiboko.openSidebar",
        "title": "NEXCODE: Open Sidebar"
      },
      {
        "command": "nexcodeKiboko.pickModel",
        "title": "NEXCODE: Pick Model"
      },
      {
        "command": "nexcodeKiboko.clearConversation",
        "title": "NEXCODE: Clear Conversation"
      },
      {
        "command": "nexcodeKiboko.openInTab",
        "title": "NEXCODE: Open In Tab"
      },
      {
        "command": "nexcodeKiboko.explainSelection",
        "title": "NEXCODE: Explain Selection"
      }
    ],
    "configuration": {
      "title": "NEXCODE-KIBOKO",
      "properties": {
        "nexcodeKiboko.defaultProvider": {
          "type": "string",
          "enum": [
            "ollama",
            "openai-compatible"
          ],
          "default": "ollama",
          "description": "Default model provider used for requests."
        },
        "nexcodeKiboko.defaultModel": {
          "type": "string",
          "default": "gpt-oss:120b-cloud",
          "description": "Default model name to send to the selected provider."
        },
        "nexcodeKiboko.defaultMode": {
          "type": "string",
          "enum": [
            "auto",
            "planner",
            "coder",
            "reviewer",
            "qa",
            "security"
          ],
          "default": "auto",
          "description": "Default agent mode for orchestration."
        },
        "nexcodeKiboko.ollamaBaseUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL for local Ollama API."
        },
        "nexcodeKiboko.openAIBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "Base URL for OpenAI-compatible API endpoint."
        },
        "nexcodeKiboko.openAIApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for OpenAI-compatible provider."
        },
        "nexcodeKiboko.tavilyApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for Tavily online web search used by /tool web-search."
        },
        "nexcodeKiboko.allowToolCommands": {
          "type": "boolean",
          "default": true,
          "description": "Allow /tool command execution from the sidebar chat."
        },
        "nexcodeKiboko.requireTerminalApproval": {
          "type": "boolean",
          "default": true,
          "description": "Require explicit confirmation in the sidebar before running /tool terminal commands."
        },
        "nexcodeKiboko.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "Default temperature for provider requests."
        },
        "nexcodeKiboko.showReasoning": {
          "type": "boolean",
          "default": true,
          "description": "Enable reasoning details panel in chat responses."
        },
        "nexcodeKiboko.autoApplyChanges": {
          "type": "boolean",
          "default": false,
          "description": "Automatically apply generated edit proposals."
        },
        "nexcodeKiboko.allowWebSearch": {
          "type": "boolean",
          "default": true,
          "description": "Allow /tool web-search commands from the sidebar."
        }
      }
    }
  },
  "scripts": {
    "build:webview:js": "esbuild webview/src/main.tsx --bundle --format=iife --platform=browser --target=es2020 --outfile=media/main.js --minify",
    "build:webview:css": "tailwindcss -i ./webview/src/styles.css -o ./media/main.css --minify",
    "build:webview": "npm run build:webview:js && npm run build:webview:css",
    "build": "npm run build:webview && tsc -p .",
    "watch": "tsc -watch -p .",
    "lint": "tsc -p . --noEmit",
    "package": "node ../tools/extension-release.mjs --no-bump --no-install"
  },
  "dependencies": {
    "@nexcode/agent-core": "^0.1.0",
    "katex": "^0.16.45",
    "lucide-react": "^1.7.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.25.11",
    "framer-motion": "^12.23.24",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "zustand": "^5.0.8"
  }
}
